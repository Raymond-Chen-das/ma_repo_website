# ──────────────────────────────────────────────────────────────
#  資料保護 / Data protection
#  Garmin 原始與逐筆資料屬第三方專有資料，嚴禁提交到版本控制。
#  Raw and row-level Garmin data is proprietary — never commit it.
# ──────────────────────────────────────────────────────────────

# 預設忽略所有 CSV（多為逐筆 Garmin 衍生資料）
*.csv

# ……但保留人工審核過、僅含「變數層級彙總」的結果檔
!results/
!results/*.csv

# 原始資料夾（含 dailies / sleeps / heartrate 等專有資料）
原始資料/
raw/
data/

# 由產生器產出的合成假資料（每次重新產生即可，不需版控）
sleep_activity_merged_final.csv

# ──────────────────────────────────────────────────────────────
#  Python / Jupyter
# ──────────────────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.pyc
.ipynb_checkpoints/

# ──────────────────────────────────────────────────────────────
#  OS / Editor
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
